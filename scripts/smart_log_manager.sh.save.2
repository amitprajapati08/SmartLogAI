#!/bin/bash

# SmartLog AI - Automated Log Monitoring and Archiving System

LOG_DIR="./logs"
ARCHIVE_DIR="./archive"
REPORT_DIR="./reports"
REPORT_FILE="./reports/activity.log"

SIZE_THRESHOLD=20

mkdir -p "$REPORT_DIR"  

echo "========== SmartLog AI Execution ==========" >> "$REPORT_FILE"
date >> "$REPORT_FILE"

# Create archive directory if not present
if [ ! -d "$ARCHIVE_DIR" ]; then
mkdir -p $ARCHIVE_DIR
fi

# Scan all logs
for file in $LOG_DIR/*
do

[ -e "$file" ] || continue

filename=$(basename "$file")

# File size in MB
filesize=$(du -m "$file" | cut -f1)

# Detect ERROR logs
error_count=$(grep -c "ERROR" "$file" 2>/dev/null)

# AI Rule 1: Large logs
if [ "$filesize" -gt "$SIZE_THRESHOLD" ]; then

echo "[AI DETECTION] Large log detected: $filename" >> $REPORT_FILE
gzip "$file"
mv "$file.gz" $ARCHIVE_DIR

# AI Rule 2: Critical error logs
elif [ "$error_count" -gt 0 ]; then

echo "[AI DETECTION] Critical error log archived: $filename" >> $REPORT_FILE
gzip "$file"
mv "$file.gz" $ARCHIVE_DIR

fi

done

echo "========== Process Completed ==========" >> $REPORT_FILE
echo "" >> $REPORT_FILE
